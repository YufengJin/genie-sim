# Required: absolute path to GenieSim assets directory
SIM_ASSETS=/path/to/your/sim_assets

# Optional: Claude Code API key (for in-container Claude Code usage)
ANTHROPIC_API_KEY=

# Optional: cuRobo GPU architecture (default 8.9 for RTX 4090)
# See: https://github.com/AgibotTech/genie_sim/issues/4
TORCH_CUDA_ARCH_LIST=8.9
